# Copy to .env for local development. NEVER commit the real .env.
SECRET_KEY=replace-with-a-long-random-string

# AI provider. Leave LLM_API_KEY blank to run in demo mode (no live AI, but
# everything else works and all usage is still logged).
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-3-5-sonnet-20241022

# For OpenAI instead:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# Database: leave unset to use local SQLite. On Render, set the Postgres URL.
# DATABASE_URL=
