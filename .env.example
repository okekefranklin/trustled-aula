# Copy to .env for local development. NEVER commit the real .env.
SECRET_KEY=replace-with-a-long-random-string

# AI provider. Leave LLM_API_KEY blank to run in demo mode (no live AI, but
# everything else works and all usage is still logged).
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-3-5-sonnet-20241022

# For OpenAI instead:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# For OpenAI-compatible providers (e.g. Groq), set a custom base URL:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Database: leave unset to use local SQLite. On Render, set the Postgres URL.
# DATABASE_URL=

# Multi-source scholarly search (OpenAlex is primary; no key required)
# RESEARCH_CONTACT_EMAIL=admin@aula.test
# OPENALEX_BASE_URL=https://api.openalex.org
# CROSSREF_BASE_URL=https://api.crossref.org
# RESEARCH_SOURCE_ORDER=OpenAlex,Semantic Scholar,CrossRef

# Semantic Scholar (optional — improves rate limits when set)
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
# SEMANTIC_SCHOLAR_API_KEY=
# SEMANTIC_SCHOLAR_MAX_RETRIES=2
# SEMANTIC_SCHOLAR_RETRY_BASE_SECONDS=2.0
# SEMANTIC_SCHOLAR_MIN_INTERVAL=1.05
